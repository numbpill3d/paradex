#!/usr/bin/env python3
"""paradex — a small vertical retro-mac terminal widget for cataloguing
aesthetics/moods/motifs and pulling a random seed set to build a concept from.
stdlib only (curses + tkinter) — deliberately not run via `uv run --script`:
uv's managed cpython builds don't reliably ship a working Tcl/Tk, tkinter fails there.
"""

import argparse
import curses
import json
import os
import random
import re
import sys
import textwrap
import tkinter as tk
import tkinter.font as tkfont
from collections import Counter
from datetime import date, datetime
from pathlib import Path

DB_PATH = Path.home() / ".local/share/paradex/db.json"
BUILDS_DIR = Path(__file__).resolve().parent / "builds"

HELP_TEXT = [
    "commands:",
    "  add <category> <text> [#tag ...]   file a new entry",
    "  edit <id> <text>                   replace an entry's text",
    "  list [category|#tag]  (ls)         show entries, optionally filtered",
    "  tag <id> #tag [#tag ...]           add tags to an entry",
    "  untag <id> #tag [#tag ...]         remove tags from an entry",
    "  mv <id> <category>                 recategorize an entry",
    "  rm <id>  (del)                     remove an entry",
    "  roll [n] [category|#tag]           randomly pull n entries (default 3)",
    "  build [name]                       save the last roll as a build sheet",
    "  export [category|#tag]             dump matching entries to builds/",
    "  categories  (cat)                  list categories + counts",
    "  tags                               list tags + counts",
    "  stats                              catalogue summary",
    "  find <term>                        search text/tags/category",
    "  clear                              drop the active filter",
    "  undo                               revert the last change",
    "  help                               this",
    "  quit  (:q, exit)                   leave",
    "",
    "examples:",
    "  add palette black voidscape, red neon veins #hackercore #ritual",
    "  add mood restless midnight circuitry #glitch",
    "  edit 3 restless 3am circuitry hum",
    "  mv 3 texture",
    "  untag 3 #glitch",
    "  roll 3 #hackercore",
    "  build my-next-thing",
    "  export #hackercore",
]

QUIT = object()


class App:
    def __init__(self):
        self.entries, self.next_id = self._load()
        self.last_roll = []
        self._undo = None

    def _snapshot(self):
        self._undo = (json.dumps(self.entries), self.next_id)

    def _load(self):
        if not DB_PATH.exists():
            return [], 1
        try:
            data = json.loads(DB_PATH.read_text())
        except (json.JSONDecodeError, OSError):
            return [], 1
        entries = data.get("entries", [])
        next_id = data.get("next_id", (max((e["id"] for e in entries), default=0) + 1))
        return entries, next_id

    def _save(self):
        DB_PATH.parent.mkdir(parents=True, exist_ok=True)
        DB_PATH.write_text(json.dumps({"entries": self.entries, "next_id": self.next_id}, indent=2))

    def _filter(self, filt):
        filt = (filt or "").strip()
        if not filt:
            return list(self.entries)
        if filt.startswith("#"):
            tag = filt[1:].lower()
            return [e for e in self.entries if tag in e["tags"]]
        cat = filt.lower()
        return [e for e in self.entries if cat in e["category"].lower()]

    def dispatch(self, raw):
        cmd, _, rest = raw.strip().partition(" ")
        cmd = cmd.lower()
        rest = rest.strip()

        if cmd in ("quit", "exit", ":q"):
            return QUIT
        if cmd in ("", "help", "?"):
            return list(HELP_TEXT), (
                "commands: add, edit, list, tag, untag, mv, rm, roll, build, export, "
                "categories, tags, stats, find, clear, undo, help, quit"
            )
        if cmd == "add":
            return self._cmd_add(rest)
        if cmd == "edit":
            return self._cmd_edit(rest)
        if cmd in ("list", "ls"):
            return self._cmd_list(rest)
        if cmd == "tag":
            return self._cmd_tag(rest)
        if cmd == "untag":
            return self._cmd_untag(rest)
        if cmd == "mv":
            return self._cmd_mv(rest)
        if cmd in ("rm", "del"):
            return self._cmd_rm(rest)
        if cmd == "roll":
            return self._cmd_roll(rest)
        if cmd == "build":
            return self._cmd_build(rest)
        if cmd == "export":
            return self._cmd_export(rest)
        if cmd in ("categories", "cat"):
            return self._cmd_categories(rest)
        if cmd == "tags":
            return self._cmd_tags(rest)
        if cmd == "stats":
            return self._cmd_stats(rest)
        if cmd == "find":
            return self._cmd_find(rest)
        if cmd == "clear":
            return self.render_list_view(list(self.entries)), "filter cleared"
        if cmd == "undo":
            return self._cmd_undo(rest)
        return [f"unknown command: '{cmd}'", "try 'help' for the command list"], f"unknown command '{cmd}'"

    def _cmd_add(self, rest):
        parts = rest.split(None, 1)
        if len(parts) < 2:
            return ["usage: add <category> <text> [#tag ...]"], "error: missing category or text"
        category, remainder = parts[0].lower(), parts[1]
        tags = sorted({t.lower() for t in re.findall(r"#(\S+)", remainder)})
        text = re.sub(r"#\S+", "", remainder)
        text = re.sub(r"\s+", " ", text).strip()
        if not text:
            return ["entry text is empty"], "error: entry text is empty"
        self._snapshot()
        eid = self.next_id
        self.next_id += 1
        entry = {"id": eid, "category": category, "text": text, "tags": tags, "created": date.today().isoformat()}
        self.entries.append(entry)
        self._save()
        return self.render_list_view(list(self.entries)), f"added [{eid}] {category}"

    def _cmd_edit(self, rest):
        parts = rest.split(None, 1)
        if len(parts) < 2:
            return ["usage: edit <id> <new text>"], "error: need an id and new text"
        try:
            eid = int(parts[0])
        except ValueError:
            return [f"'{parts[0]}' is not a valid id"], "error: bad id"
        entry = next((e for e in self.entries if e["id"] == eid), None)
        if entry is None:
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        text = re.sub(r"\s+", " ", parts[1]).strip()
        if not text:
            return ["entry text is empty"], "error: entry text is empty"
        self._snapshot()
        entry["text"] = text
        self._save()
        return self.render_list_view([entry]), f"edited [{eid}]"

    def _cmd_list(self, rest):
        filtered = self._filter(rest)
        label = f" matching '{rest}'" if rest else ""
        noun = "entry" if len(filtered) == 1 else "entries"
        return self.render_list_view(filtered), f"{len(filtered)} {noun}{label}"

    def _cmd_tag(self, rest):
        parts = rest.split()
        if len(parts) < 2:
            return ["usage: tag <id> #tag [#tag ...]"], "error: need an id and at least one tag"
        try:
            eid = int(parts[0])
        except ValueError:
            return [f"'{parts[0]}' is not a valid id"], "error: bad id"
        entry = next((e for e in self.entries if e["id"] == eid), None)
        if entry is None:
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        new_tags = sorted({t.lstrip("#").lower() for t in parts[1:]})
        self._snapshot()
        entry["tags"] = sorted(set(entry["tags"]) | set(new_tags))
        self._save()
        return self.render_list_view([entry]), f"tagged [{eid}]: +" + " +".join(new_tags)

    def _cmd_untag(self, rest):
        parts = rest.split()
        if len(parts) < 2:
            return ["usage: untag <id> #tag [#tag ...]"], "error: need an id and at least one tag"
        try:
            eid = int(parts[0])
        except ValueError:
            return [f"'{parts[0]}' is not a valid id"], "error: bad id"
        entry = next((e for e in self.entries if e["id"] == eid), None)
        if entry is None:
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        drop = sorted({t.lstrip("#").lower() for t in parts[1:]})
        self._snapshot()
        entry["tags"] = sorted(set(entry["tags"]) - set(drop))
        self._save()
        return self.render_list_view([entry]), f"untagged [{eid}]: -" + " -".join(drop)

    def _cmd_mv(self, rest):
        parts = rest.split(None, 1)
        if len(parts) < 2:
            return ["usage: mv <id> <category>"], "error: need an id and a category"
        try:
            eid = int(parts[0])
        except ValueError:
            return [f"'{parts[0]}' is not a valid id"], "error: bad id"
        entry = next((e for e in self.entries if e["id"] == eid), None)
        if entry is None:
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        new_cat = parts[1].strip().lower()
        if not new_cat:
            return ["usage: mv <id> <category>"], "error: empty category"
        self._snapshot()
        old_cat = entry["category"]
        entry["category"] = new_cat
        self._save()
        return self.render_list_view([entry]), f"moved [{eid}]: {old_cat} -> {new_cat}"

    def _cmd_rm(self, rest):
        try:
            eid = int(rest.strip())
        except ValueError:
            return ["usage: rm <id>"], "error: bad id"
        before = len(self.entries)
        self._snapshot()
        self.entries = [e for e in self.entries if e["id"] != eid]
        if len(self.entries) == before:
            self._undo = None
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        self._save()
        return self.render_list_view(list(self.entries)), f"removed [{eid}]"

    def _cmd_undo(self, rest):
        if self._undo is None:
            return ["nothing to undo"], "error: no undo history"
        entries_json, next_id = self._undo
        self.entries = json.loads(entries_json)
        self.next_id = next_id
        self._undo = None
        self._save()
        return self.render_list_view(list(self.entries)), "undone — reverted last change"

    def _cmd_roll(self, rest):
        parts = rest.split()
        n = 3
        filt = rest
        if parts and parts[0].isdigit():
            n = int(parts[0])
            filt = " ".join(parts[1:])
        pool = self._filter(filt)
        if not pool:
            return ["no entries match — add some first."], "error: nothing to roll"
        n = min(n, len(pool))
        self.last_roll = random.sample(pool, n)
        view = ["THE PULL", ""] + self._entry_lines(self.last_roll)
        return view, f"rolled {n} — 'build [name]' to save this seed"

    def _cmd_build(self, rest):
        if not self.last_roll:
            return ["nothing rolled yet — try 'roll' first."], "error: nothing to build from"
        name = rest.strip() or datetime.now().strftime("seed-%Y%m%d-%H%M%S")
        path = self._build_path(name)
        content = self._build_sheet(name, self.last_roll)
        path.write_text(content)
        return content.splitlines(), f"saved -> builds/{path.name}"

    def _cmd_export(self, rest):
        entries = self._filter(rest)
        if not entries:
            return ["no entries match — nothing to export."], "error: nothing to export"
        label = rest.strip() or "full catalogue"
        path = self._build_path(f"export-{label}")
        content = self._build_sheet(label, entries, kind="EXPORT")
        path.write_text(content)
        return content.splitlines(), f"saved -> builds/{path.name}"

    def _build_path(self, name):
        slug = re.sub(r"[^a-z0-9-]+", "-", name.lower()).strip("-") or "seed"
        BUILDS_DIR.mkdir(parents=True, exist_ok=True)
        path = BUILDS_DIR / f"{slug}.txt"
        i = 2
        while path.exists():
            path = BUILDS_DIR / f"{slug}-{i}.txt"
            i += 1
        return path

    def _cmd_categories(self, rest):
        counts = Counter(e["category"] for e in self.entries)
        if not counts:
            return ["(no entries yet)"], "0 categories"
        lines = [f"{cat}  ({n})" for cat, n in sorted(counts.items(), key=lambda kv: -kv[1])]
        return lines, f"{len(counts)} categories, {len(self.entries)} entries total"

    def _cmd_tags(self, rest):
        counts = Counter(t for e in self.entries for t in e["tags"])
        if not counts:
            return ["(no tags yet)"], "0 tags"
        lines = [f"#{tag}  ({n})" for tag, n in sorted(counts.items(), key=lambda kv: -kv[1])]
        return lines, f"{len(counts)} tags"

    def _cmd_stats(self, rest):
        if not self.entries:
            return ["(no entries yet)"], "0 entries"
        cats = Counter(e["category"] for e in self.entries)
        tags = Counter(t for e in self.entries for t in e["tags"])
        dates = sorted(e["created"] for e in self.entries)
        lines = [
            f"{len(self.entries)} entries",
            f"{len(cats)} categories, {len(tags)} tags",
            f"oldest {dates[0]}  newest {dates[-1]}",
            "",
            "top categories:",
        ]
        lines += [f"  {cat} ({n})" for cat, n in cats.most_common(3)]
        if tags:
            lines.append("")
            lines.append("top tags:")
            lines += [f"  #{tag} ({n})" for tag, n in tags.most_common(3)]
        return lines, f"{len(self.entries)} entries total"

    def _cmd_find(self, rest):
        term = rest.strip().lower()
        if not term:
            return ["usage: find <term>"], "error: empty search"
        results = [
            e for e in self.entries
            if term in e["text"].lower() or term in e["category"].lower() or any(term in t for t in e["tags"])
        ]
        noun = "match" if len(results) == 1 else "matches"
        return self.render_list_view(results), f"{len(results)} {noun} for '{term}'"

    def _entry_lines(self, entries, width=34):
        lines = []
        for e in entries:
            tagstr = (" {" + " ".join("#" + t for t in e["tags"]) + "}") if e["tags"] else ""
            body = f"[{e['id']}] {e['category']} — {e['text']}{tagstr}"
            lines.extend(textwrap.wrap(body, width=width, subsequent_indent="    ") or [""])
        return lines

    def render_list_view(self, entries, width=34, max_lines=18):
        if not entries:
            return ["(nothing here yet)", "try: add mood <text> #tag"]
        entries = sorted(entries, key=lambda e: -e["id"])
        lines, shown = [], 0
        for e in entries:
            wrapped = self._entry_lines([e], width=width)
            if len(lines) + len(wrapped) > max_lines - 1 and shown < len(entries):
                lines.append(f"...and {len(entries) - shown} more (narrow with find/list)")
                break
            lines.extend(wrapped)
            shown += 1
        return lines

    def render_initial(self):
        if not self.entries:
            return ["welcome to paradex.", "", "file the aesthetics you keep", "coming back to. pull a random", "set later to seed a concept.", "", "try:", "  add mood <text> #tag", "  help"]
        return self.render_list_view(list(self.entries))

    def _build_sheet(self, name, entries, kind="BUILD SHEET"):
        by_cat = {}
        for e in entries:
            by_cat.setdefault(e["category"], []).append(e)
        out = [f"PARADEX {kind} — {name}", f"generated {date.today().isoformat()}", ""]
        for cat, es in sorted(by_cat.items()):
            out.append(cat.upper())
            for e in es:
                tagstr = (" [" + " ".join("#" + t for t in e["tags"]) + "]") if e["tags"] else ""
                out.append(f"  - {e['text']}{tagstr}")
            out.append("")
        if kind == "BUILD SHEET":
            out.append("---")
            out.append("seed for:")
            out.append("")
        return "\n".join(out)


def safe_addstr(stdscr, y, x, text, attr=0):
    try:
        stdscr.addstr(y, x, text, attr)
    except curses.error:
        pass


# ---------------------------------------------------------------------------
# shared chrome/content rendering — a plain list[str] box, used by both the
# curses backend (blitted at an x0,y0 offset inside the real terminal) and
# the tkinter backend (the box IS the whole window, no host terminal).
# ---------------------------------------------------------------------------

def render_box_lines(view, status, buf, cursor, fw, fh, inner_w, content_h, title):
    """returns (lines, title_row, input_row, input_col) — lines[i] is exactly
    fw chars wide; title_row/input_row are indices into lines; input_col is
    the char column (within the line) where the text-entry cursor sits.

    border is a subtle bevel: crisp "─│" on the top/left (raised edge), soft
    "░" shade on the bottom/right (recessed edge) — glyph-only, no color."""
    lines = []
    lines.append("┌" + "─" * inner_w + "┐")

    left_box, right_box = "[■]", "[■]"
    label = f" {title} "
    stripe_total = max(0, inner_w - len(left_box) - len(right_box) - len(label))
    left_stripe = "·" * (stripe_total // 2)
    right_stripe = "·" * (stripe_total - stripe_total // 2)
    title_line = (left_box + left_stripe + label + right_stripe + right_box)[:inner_w].ljust(inner_w)
    lines.append("│" + title_line + "░")
    title_row = 1

    lines.append("├" + "─" * inner_w + "┤")

    for i in range(content_h):
        text = (view[i] if i < len(view) else "")[:inner_w].ljust(inner_w)
        lines.append("│" + text + "░")

    status_text = ("◆ " + status)[:inner_w].ljust(inner_w)
    lines.append("│" + status_text + "░")
    lines.append("├" + "─" * inner_w + "┤")

    full_prompt = "> " + "".join(buf)
    cursor_pos = 2 + cursor
    if len(full_prompt) <= inner_w:
        view_start = 0
    else:
        max_start = len(full_prompt) - inner_w
        view_start = min(max(cursor_pos - inner_w + 1, 0), max_start)
        if cursor_pos < view_start:
            view_start = cursor_pos
    visible = full_prompt[view_start:view_start + inner_w].ljust(inner_w)
    input_row = len(lines)
    lines.append("│" + visible + "░")
    input_col = 1 + (cursor_pos - view_start)

    lines.append("░" * (inner_w + 2))

    return lines, title_row, input_row, input_col


CONTENT_H, INNER_W = 18, 34


def handle_key(app, buf, cursor, history, hist_idx, control):
    """apply one logical keypress. `control` is one of the KEY_* sentinels
    below, or a single printable character. returns (buf, cursor, hist_idx,
    view_status_or_None) — view_status_or_None is (view, status) on submit,
    QUIT on quit, else None."""
    if control == "ENTER":
        raw = "".join(buf)
        if raw.strip():
            history.append(raw)
        hist_idx = len(history)
        result = app.dispatch(raw)
        if result is QUIT:
            return buf, cursor, hist_idx, QUIT
        return [], 0, hist_idx, result
    if control == "BACKSPACE":
        if cursor > 0:
            del buf[cursor - 1]
            cursor -= 1
    elif control == "DELETE":
        if cursor < len(buf):
            del buf[cursor]
    elif control == "LEFT":
        cursor = max(0, cursor - 1)
    elif control == "RIGHT":
        cursor = min(len(buf), cursor + 1)
    elif control == "HOME":
        cursor = 0
    elif control == "END":
        cursor = len(buf)
    elif control == "UP":
        if history and hist_idx > 0:
            hist_idx -= 1
            buf = list(history[hist_idx])
            cursor = len(buf)
    elif control == "DOWN":
        if hist_idx < len(history) - 1:
            hist_idx += 1
            buf = list(history[hist_idx])
            cursor = len(buf)
        else:
            hist_idx = len(history)
            buf, cursor = [], 0
    elif isinstance(control, str) and len(control) == 1:
        buf.insert(cursor, control)
        cursor += 1
    return buf, cursor, hist_idx, None


# ---------------------------------------------------------------------------
# curses backend
# ---------------------------------------------------------------------------

def cmd_tui(_args):
    curses.wrapper(_curses_main)


def _curses_main(stdscr):
    curses.curs_set(1)
    curses.start_color()
    curses.init_pair(1, curses.COLOR_BLACK, curses.COLOR_WHITE)
    pair = curses.color_pair(1)
    stdscr.keypad(True)

    term_h, term_w = stdscr.getmaxyx()
    content_h, inner_w = CONTENT_H, INNER_W
    fw, fh = inner_w + 2, content_h + 7
    while fh > term_h - 1 and content_h > 8:
        content_h -= 1
        fh = content_h + 7
    while fw > term_w - 1 and inner_w > 24:
        inner_w -= 2
        fw = inner_w + 2
    if fh > term_h - 1 or fw > term_w - 1:
        stdscr.erase()
        safe_addstr(stdscr, 0, 0, f"terminal too small — need at least {fw + 2} x {fh + 2}")
        stdscr.refresh()
        stdscr.getch()
        return

    x0 = max(0, (term_w - fw) // 2)
    y0 = max(0, (term_h - fh) // 2)

    app = App()
    view = app.render_initial()
    status = f"{len(app.entries)} entries loaded" if app.entries else "welcome — try: add mood <text> #tag"
    buf, cursor = [], 0
    history, hist_idx = [], 0

    while True:
        lines, _title_row, input_row, input_col = render_box_lines(
            view, status, buf, cursor, fw, fh, inner_w, content_h, "PARADEX")
        stdscr.erase()
        for i, line in enumerate(lines):
            attr = pair | (curses.A_BOLD if i == 1 else 0)
            safe_addstr(stdscr, y0 + i, x0, line, attr)
        try:
            stdscr.move(y0 + input_row, x0 + input_col)
        except curses.error:
            pass
        stdscr.refresh()

        ch = stdscr.getch()
        if ch in (10, 13, curses.KEY_ENTER):
            control = "ENTER"
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            control = "BACKSPACE"
        elif ch == curses.KEY_DC:
            control = "DELETE"
        elif ch == curses.KEY_LEFT:
            control = "LEFT"
        elif ch == curses.KEY_RIGHT:
            control = "RIGHT"
        elif ch == curses.KEY_HOME:
            control = "HOME"
        elif ch == curses.KEY_END:
            control = "END"
        elif ch == curses.KEY_UP:
            control = "UP"
        elif ch == curses.KEY_DOWN:
            control = "DOWN"
        elif ch == curses.KEY_RESIZE:
            continue
        elif 32 <= ch < 127:
            control = chr(ch)
        else:
            continue

        buf, cursor, hist_idx, result = handle_key(app, buf, cursor, history, hist_idx, control)
        if result is QUIT:
            break
        if result is not None:
            view, status = result


