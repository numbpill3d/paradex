#!/usr/bin/env python3
"""paradex — a small vertical retro-mac terminal widget for cataloguing
aesthetics/moods/motifs and pulling a random seed set to build a concept from.
stdlib only (curses + tkinter) — deliberately not run via `uv run --script`:
uv's managed cpython builds don't reliably ship a working Tcl/Tk, tkinter fails there.
"""

import argparse
import curses
import json
import os
import random
import re
import sys
import textwrap
import tkinter as tk
import tkinter.font as tkfont
from collections import Counter
from datetime import date, datetime
from pathlib import Path

DB_PATH = Path.home() / ".local/share/paradex/db.json"
BUILDS_DIR = Path.home() / ".local/share/paradex/builds"
PROJECT_STATUSES = ("seed", "active", "shelved", "done")

HELP_TEXT = [
    "commands:",
    "  add <category> <text> [#tag ...]   file a new entry",
    "  edit <id> <text>                   replace an entry's text",
    "  list [category|#tag|@project]      show entries, optionally filtered",
    "  tag <id> #tag [#tag ...]           add tags to an entry",
    "  untag <id> #tag [#tag ...]         remove tags from an entry",
    "  mv <id> <category>                 recategorize an entry",
    "  rm <id>  (del)                     remove an entry",
    "  link <id> <id>                     mark two entries as compatible",
    "  unlink <id> <id>                   remove a link",
    "  clash <id> <id>                    mark two entries as conflicting",
    "  unclash <id> <id>                  remove a clash",
    "  roll [n] [category|#tag|@project]  randomly pull n entries (default 3)",
    "  roll spread <name>                 one guaranteed pull per spread category",
    "  spread <name> <cat> [cat ...]      define a named set of categories",
    "  spreads                            list saved spreads",
    "  build [name]                       save the last roll as a build sheet",
    "  export [category|#tag|@project]    dump matching entries to builds/",
    "  newproj <name>                     start a tracked project",
    "  projects [id]                      list projects, or show one in detail",
    "  pin <project-id> <id> [id ...]     pin entries to a project",
    "  unpin <project-id> <id> [id ...]   unpin entries from a project",
    "  status <project-id> <stage>        seed | active | shelved | done",
    "  note <project-id> <text>           set a project's notes",
    "  rmproj <project-id>                delete a project (not its entries)",
    "  categories  (cat)                  list categories + counts",
    "  tags                               list tags + counts",
    "  stats                              catalogue summary",
    "  find <term>                        search text/tags/category",
    "  clear                              drop the active filter",
    "  undo                               revert the last change",
    "  help                               this",
    "  quit  (:q, exit)                   leave",
    "",
    "examples:",
    "  add palette black voidscape, red neon veins #hackercore #ritual",
    "  add mood restless midnight circuitry #glitch",
    "  link 1 2",
    "  spread concept mood palette texture mechanic",
    "  roll spread concept",
    "  newproj wraith-game",
    "  pin 1 1 2 3",
    "  status 1 active",
    "  roll 3 @wraith-game",
]

QUIT = object()


class App:
    def __init__(self):
        self.entries, self.next_id, self.projects, self.next_project_id, self.spreads = self._load()
        self.last_roll = []
        self._undo = None

    def _snapshot(self):
        self._undo = json.dumps({
            "entries": self.entries,
            "next_id": self.next_id,
            "projects": self.projects,
            "next_project_id": self.next_project_id,
            "spreads": self.spreads,
        })

    def _load(self):
        if not DB_PATH.exists():
            return [], 1, [], 1, {}
        try:
            data = json.loads(DB_PATH.read_text())
        except (json.JSONDecodeError, OSError):
            return [], 1, [], 1, {}
        entries = data.get("entries", [])
        for e in entries:
            e.setdefault("links", [])
            e.setdefault("clashes", [])
        next_id = data.get("next_id", (max((e["id"] for e in entries), default=0) + 1))
        projects = data.get("projects", [])
        next_project_id = data.get("next_project_id", (max((p["id"] for p in projects), default=0) + 1))
        spreads = data.get("spreads", {})
        return entries, next_id, projects, next_project_id, spreads

    def _save(self):
        DB_PATH.parent.mkdir(parents=True, exist_ok=True)
        DB_PATH.write_text(json.dumps({
            "entries": self.entries,
            "next_id": self.next_id,
            "projects": self.projects,
            "next_project_id": self.next_project_id,
            "spreads": self.spreads,
        }, indent=2))

    def _filter(self, filt):
        filt = (filt or "").strip()
        if not filt:
            return list(self.entries)
        if filt.startswith("#"):
            tag = filt[1:].lower()
            return [e for e in self.entries if tag in e["tags"]]
        if filt.startswith("@"):
            ref = filt[1:].lower()
            proj = next((p for p in self.projects if str(p["id"]) == ref), None)
            if proj is None:
                proj = next((p for p in self.projects if ref in p["name"].lower()), None)
            if proj is None:
                return []
            return [e for e in self.entries if e["id"] in proj["entry_ids"]]
        cat = filt.lower()
        return [e for e in self.entries if cat in e["category"].lower()]

    def dispatch(self, raw):
        cmd, _, rest = raw.strip().partition(" ")
        cmd = cmd.lower()
        rest = rest.strip()

        if cmd in ("quit", "exit", ":q"):
            return QUIT
        if cmd in ("", "help", "?"):
            return list(HELP_TEXT), (
                "commands: add, edit, list, tag, untag, mv, rm, link, unlink, clash, "
                "unclash, roll, spread, build, export, newproj, projects, pin, unpin, "
                "status, note, rmproj, categories, tags, stats, find, clear, undo, help, quit"
            )
        if cmd == "add":
            return self._cmd_add(rest)
        if cmd == "edit":
            return self._cmd_edit(rest)
        if cmd in ("list", "ls"):
            return self._cmd_list(rest)
        if cmd == "tag":
            return self._cmd_tag(rest)
        if cmd == "untag":
            return self._cmd_untag(rest)
        if cmd == "mv":
            return self._cmd_mv(rest)
        if cmd in ("rm", "del"):
            return self._cmd_rm(rest)
        if cmd == "link":
            return self._link_pair(rest, "links", add=True, name="link")
        if cmd == "unlink":
            return self._link_pair(rest, "links", add=False, name="unlink")
        if cmd == "clash":
            return self._link_pair(rest, "clashes", add=True, name="clash")
        if cmd == "unclash":
            return self._link_pair(rest, "clashes", add=False, name="unclash")
        if cmd == "roll":
            return self._cmd_roll(rest)
        if cmd == "spread":
            return self._cmd_spread(rest)
        if cmd == "spreads":
            return self._cmd_spreads(rest)
        if cmd == "build":
            return self._cmd_build(rest)
        if cmd == "export":
            return self._cmd_export(rest)
        if cmd == "newproj":
            return self._cmd_newproj(rest)
        if cmd in ("projects", "projs"):
            return self._cmd_projects(rest)
        if cmd == "pin":
            return self._proj_pin(rest, add=True)
        if cmd == "unpin":
            return self._proj_pin(rest, add=False)
        if cmd == "status":
            return self._cmd_status(rest)
        if cmd == "note":
            return self._cmd_note(rest)
        if cmd == "rmproj":
            return self._cmd_rmproj(rest)
        if cmd in ("categories", "cat"):
            return self._cmd_categories(rest)
        if cmd == "tags":
            return self._cmd_tags(rest)
        if cmd == "stats":
            return self._cmd_stats(rest)
        if cmd == "find":
            return self._cmd_find(rest)
        if cmd == "clear":
            return self.render_list_view(list(self.entries)), "filter cleared"
        if cmd == "undo":
            return self._cmd_undo(rest)
        return [f"unknown command: '{cmd}'", "try 'help' for the command list"], f"unknown command '{cmd}'"

    # -- entries ----------------------------------------------------------

    def _cmd_add(self, rest):
        parts = rest.split(None, 1)
        if len(parts) < 2:
            return ["usage: add <category> <text> [#tag ...]"], "error: missing category or text"
        category, remainder = parts[0].lower(), parts[1]
        tags = sorted({t.lower() for t in re.findall(r"#(\S+)", remainder)})
        text = re.sub(r"#\S+", "", remainder)
        text = re.sub(r"\s+", " ", text).strip()
        if not text:
            return ["entry text is empty"], "error: entry text is empty"
        self._snapshot()
        eid = self.next_id
        self.next_id += 1
        entry = {
            "id": eid, "category": category, "text": text, "tags": tags,
            "created": date.today().isoformat(), "links": [], "clashes": [],
        }
        self.entries.append(entry)
        self._save()
        return self.render_list_view(list(self.entries)), f"added [{eid}] {category}"

    def _cmd_edit(self, rest):
        parts = rest.split(None, 1)
        if len(parts) < 2:
            return ["usage: edit <id> <new text>"], "error: need an id and new text"
        try:
            eid = int(parts[0])
        except ValueError:
            return [f"'{parts[0]}' is not a valid id"], "error: bad id"
        entry = next((e for e in self.entries if e["id"] == eid), None)
        if entry is None:
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        text = re.sub(r"\s+", " ", parts[1]).strip()
        if not text:
            return ["entry text is empty"], "error: entry text is empty"
        self._snapshot()
        entry["text"] = text
        self._save()
        return self.render_list_view([entry]), f"edited [{eid}]"

    def _cmd_list(self, rest):
        filtered = self._filter(rest)
        label = f" matching '{rest}'" if rest else ""
        noun = "entry" if len(filtered) == 1 else "entries"
        return self.render_list_view(filtered), f"{len(filtered)} {noun}{label}"

    def _cmd_tag(self, rest):
        parts = rest.split()
        if len(parts) < 2:
            return ["usage: tag <id> #tag [#tag ...]"], "error: need an id and at least one tag"
        try:
            eid = int(parts[0])
        except ValueError:
            return [f"'{parts[0]}' is not a valid id"], "error: bad id"
        entry = next((e for e in self.entries if e["id"] == eid), None)
        if entry is None:
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        new_tags = sorted({t.lstrip("#").lower() for t in parts[1:]})
        self._snapshot()
        entry["tags"] = sorted(set(entry["tags"]) | set(new_tags))
        self._save()
        return self.render_list_view([entry]), f"tagged [{eid}]: +" + " +".join(new_tags)

    def _cmd_untag(self, rest):
        parts = rest.split()
        if len(parts) < 2:
            return ["usage: untag <id> #tag [#tag ...]"], "error: need an id and at least one tag"
        try:
            eid = int(parts[0])
        except ValueError:
            return [f"'{parts[0]}' is not a valid id"], "error: bad id"
        entry = next((e for e in self.entries if e["id"] == eid), None)
        if entry is None:
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        drop = sorted({t.lstrip("#").lower() for t in parts[1:]})
        self._snapshot()
        entry["tags"] = sorted(set(entry["tags"]) - set(drop))
        self._save()
        return self.render_list_view([entry]), f"untagged [{eid}]: -" + " -".join(drop)

    def _cmd_mv(self, rest):
        parts = rest.split(None, 1)
        if len(parts) < 2:
            return ["usage: mv <id> <category>"], "error: need an id and a category"
        try:
            eid = int(parts[0])
        except ValueError:
            return [f"'{parts[0]}' is not a valid id"], "error: bad id"
        entry = next((e for e in self.entries if e["id"] == eid), None)
        if entry is None:
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        new_cat = parts[1].strip().lower()
        if not new_cat:
            return ["usage: mv <id> <category>"], "error: empty category"
        self._snapshot()
        old_cat = entry["category"]
        entry["category"] = new_cat
        self._save()
        return self.render_list_view([entry]), f"moved [{eid}]: {old_cat} -> {new_cat}"

    def _cmd_rm(self, rest):
        try:
            eid = int(rest.strip())
        except ValueError:
            return ["usage: rm <id>"], "error: bad id"
        before = len(self.entries)
        self._snapshot()
        self.entries = [e for e in self.entries if e["id"] != eid]
        if len(self.entries) == before:
            self._undo = None
            return [f"no entry [{eid}]"], f"error: no entry [{eid}]"
        self._save()
        return self.render_list_view(list(self.entries)), f"removed [{eid}]"

    def _cmd_undo(self, rest):
        if self._undo is None:
            return ["nothing to undo"], "error: no undo history"
        state = json.loads(self._undo)
        self.entries = state["entries"]
        self.next_id = state["next_id"]
        self.projects = state["projects"]
        self.next_project_id = state["next_project_id"]
        self.spreads = state["spreads"]
        self._undo = None
        self._save()
        return self.render_list_view(list(self.entries)), "undone — reverted last change"

    # -- relationships ------------------------------------------------------

    def _link_pair(self, rest, field, add, name):
        parts = rest.split()
        if len(parts) != 2:
            return [f"usage: {name} <id1> <id2>"], "error: need exactly two entry ids"
        try:
            a_id, b_id = int(parts[0]), int(parts[1])
        except ValueError:
            return ["ids must be numbers"], "error: bad id"
        if a_id == b_id:
            return ["can't link an entry to itself"], "error: same id twice"
        a = next((e for e in self.entries if e["id"] == a_id), None)
        b = next((e for e in self.entries if e["id"] == b_id), None)
        if a is None or b is None:
            missing = a_id if a is None else b_id
            return [f"no entry [{missing}]"], f"error: no entry [{missing}]"
        self._snapshot()
        if add:
            a[field] = sorted(set(a[field]) | {b_id})
            b[field] = sorted(set(b[field]) | {a_id})
        else:
            a[field] = sorted(set(a[field]) - {b_id})
            b[field] = sorted(set(b[field]) - {a_id})
        self._save()
        return self.render_list_view([a, b]), f"{name} [{a_id}] <-> [{b_id}]"

    def _pick_weighted(self, pool, picked):
        picked_ids = {e["id"] for e in picked}
        valid = [e for e in pool if not (set(e.get("clashes", [])) & picked_ids)]
        if not valid:
            valid = list(pool)
        weights = [1 + 3 * len(set(e.get("links", [])) & picked_ids) for e in valid]
        return random.choices(valid, weights=weights, k=1)[0]

    # -- rolling / spreads ---------------------------------------------------

    def _cmd_roll(self, rest):
        parts = rest.split()
        if parts and parts[0].lower() == "spread":
            return self._cmd_roll_spread(rest[len(parts[0]):].strip())
        n = 3
        filt = rest
        if parts and parts[0].isdigit():
            n = int(parts[0])
            filt = " ".join(parts[1:])
        pool = self._filter(filt)
        if not pool:
            return ["no entries match — add some first."], "error: nothing to roll"
        n = min(n, len(pool))
        picked, remaining = [], list(pool)
        for _ in range(n):
            choice = self._pick_weighted(remaining, picked)
            picked.append(choice)
            remaining.remove(choice)
        self.last_roll = picked
        view = ["THE PULL", ""] + self._entry_lines(self.last_roll)
        return view, f"rolled {n} — 'build [name]' to save this seed"

    def _cmd_roll_spread(self, name):
        name = name.strip().lower()
        if not name:
            return ["usage: roll spread <name>"], "error: missing spread name"
        cats = self.spreads.get(name)
        if cats is None:
            return [f"no spread named '{name}' — try 'spreads'"], f"error: no spread '{name}'"
        picked, missing = [], []
        for cat in cats:
            pool = [e for e in self.entries if e["category"].lower() == cat]
            if not pool:
                missing.append(cat)
                continue
            picked.append(self._pick_weighted(pool, picked))
        if not picked:
            return [f"no entries in any category for spread '{name}'."], "error: nothing to roll"
        self.last_roll = picked
        view = [f"SPREAD: {name}", ""] + self._entry_lines(self.last_roll)
        status = f"rolled spread '{name}' ({len(picked)}/{len(cats)})"
        if missing:
            status += " — missing: " + ", ".join(missing)
        return view, status

    def _cmd_spread(self, rest):
        parts = rest.split()
        if len(parts) < 2:
            return ["usage: spread <name> <category> [category ...]"], "error: need a name and at least one category"
        name = parts[0].lower()
        cats = [c.lower() for c in parts[1:]]
        self._snapshot()
        self.spreads[name] = cats
        self._save()
        return [f"spread '{name}': " + " + ".join(cats)], f"saved spread '{name}'"

    def _cmd_spreads(self, rest):
        if not self.spreads:
            return ["(no spreads yet)", "try: spread concept mood palette texture"], "0 spreads"
        lines = [f"{name}: " + " + ".join(cats) for name, cats in sorted(self.spreads.items())]
        return lines, f"{len(self.spreads)} spreads"

    # -- build / export ------------------------------------------------------

    def _cmd_build(self, rest):
        if not self.last_roll:
            return ["nothing rolled yet — try 'roll' first."], "error: nothing to build from"
        name = rest.strip() or datetime.now().strftime("seed-%Y%m%d-%H%M%S")
        path = self._build_path(name)
        content = self._build_sheet(name, self.last_roll)
        path.write_text(content)
        return content.splitlines(), f"saved -> builds/{path.name}"

    def _cmd_export(self, rest):
        entries = self._filter(rest)
        if not entries:
            return ["no entries match — nothing to export."], "error: nothing to export"
        label = self._filter_label(rest)
        path = self._build_path(f"export-{label}")
        content = self._build_sheet(label, entries, kind="EXPORT")
        path.write_text(content)
        return content.splitlines(), f"saved -> builds/{path.name}"

    def _filter_label(self, filt):
        filt = (filt or "").strip()
        if not filt:
            return "full catalogue"
        if filt.startswith("@"):
            ref = filt[1:].lower()
            proj = next((p for p in self.projects if str(p["id"]) == ref), None)
            if proj is None:
                proj = next((p for p in self.projects if ref in p["name"].lower()), None)
            if proj is not None:
                return proj["name"]
        return filt

    def _build_path(self, name):
        slug = re.sub(r"[^a-z0-9-]+", "-", name.lower()).strip("-") or "seed"
        BUILDS_DIR.mkdir(parents=True, exist_ok=True)
        path = BUILDS_DIR / f"{slug}.txt"
        i = 2
        while path.exists():
            path = BUILDS_DIR / f"{slug}-{i}.txt"
            i += 1
        return path

    # -- projects -------------------------------------------------------------

    def _cmd_newproj(self, rest):
        name = rest.strip()
        if not name:
            return ["usage: newproj <name>"], "error: missing name"
        self._snapshot()
        pid = self.next_project_id
        self.next_project_id += 1
        proj = {
            "id": pid, "name": name, "status": "seed", "notes": "",
            "entry_ids": [], "created": date.today().isoformat(),
        }
        self.projects.append(proj)
        self._save()
        return [f"[{pid}] {name}  (seed)"], f"created project [{pid}] {name}"

    def _cmd_projects(self, rest):
        rest = rest.strip()
        if rest:
            try:
                pid = int(rest)
            except ValueError:
                return [f"'{rest}' is not a valid project id"], "error: bad id"
            proj = next((p for p in self.projects if p["id"] == pid), None)
            if proj is None:
                return [f"no project [{pid}]"], f"error: no project [{pid}]"
            return self._project_detail(proj), f"project [{pid}] {proj['name']}"
        if not self.projects:
            return ["(no projects yet)", "try: newproj my-next-thing"], "0 projects"
        lines = [f"[{p['id']}] {p['name']}  ({p['status']}, {len(p['entry_ids'])} pinned)" for p in self.projects]
        return lines, f"{len(self.projects)} projects"

    def _project_detail(self, proj):
        lines = [f"[{proj['id']}] {proj['name']}", f"status: {proj['status']}", ""]
        if proj["notes"]:
            lines += ["notes:", proj["notes"], ""]
        pinned = [e for e in self.entries if e["id"] in proj["entry_ids"]]
        if pinned:
            lines.append("pinned:")
            lines += self._entry_lines(pinned)
        else:
            lines.append("(nothing pinned yet)")
        return lines

    def _proj_pin(self, rest, add):
        parts = rest.split()
        verb = "pin" if add else "unpin"
        if len(parts) < 2:
            return [f"usage: {verb} <project-id> <entry-id> [entry-id ...]"], "error: need a project id and at least one entry id"
        try:
            pid = int(parts[0])
            eids = [int(p) for p in parts[1:]]
        except ValueError:
            return ["ids must be numbers"], "error: bad id"
        proj = next((p for p in self.projects if p["id"] == pid), None)
        if proj is None:
            return [f"no project [{pid}]"], f"error: no project [{pid}]"
        valid_ids = {e["id"] for e in self.entries}
        missing = [i for i in eids if i not in valid_ids]
        if missing:
            return [f"no entry {missing}"], f"error: no entry {missing}"
        self._snapshot()
        if add:
            proj["entry_ids"] = sorted(set(proj["entry_ids"]) | set(eids))
        else:
            proj["entry_ids"] = sorted(set(proj["entry_ids"]) - set(eids))
        self._save()
        action = "pinned" if add else "unpinned"
        return self._project_detail(proj), f"{action} {eids} -> [{pid}] {proj['name']}"

    def _cmd_status(self, rest):
        parts = rest.split()
        if len(parts) != 2 or parts[1].lower() not in PROJECT_STATUSES:
            return [f"usage: status <project-id> <{'|'.join(PROJECT_STATUSES)}>"], "error: bad status"
        try:
            pid = int(parts[0])
        except ValueError:
            return ["ids must be numbers"], "error: bad id"
        proj = next((p for p in self.projects if p["id"] == pid), None)
        if proj is None:
            return [f"no project [{pid}]"], f"error: no project [{pid}]"
        self._snapshot()
        proj["status"] = parts[1].lower()
        self._save()
        return [f"[{pid}] {proj['name']}  ({proj['status']})"], f"status [{pid}] -> {proj['status']}"

    def _cmd_note(self, rest):
        parts = rest.split(None, 1)
        if not parts:
            return ["usage: note <project-id> <text>"], "error: need a project id"
        try:
            pid = int(parts[0])
        except ValueError:
            return ["ids must be numbers"], "error: bad id"
        proj = next((p for p in self.projects if p["id"] == pid), None)
        if proj is None:
            return [f"no project [{pid}]"], f"error: no project [{pid}]"
        text = parts[1].strip() if len(parts) > 1 else ""
        self._snapshot()
        proj["notes"] = text
        self._save()
        return self._project_detail(proj), f"note set [{pid}]"

    def _cmd_rmproj(self, rest):
        try:
            pid = int(rest.strip())
        except ValueError:
            return ["usage: rmproj <project-id>"], "error: bad id"
        before = len(self.projects)
        self._snapshot()
        self.projects = [p for p in self.projects if p["id"] != pid]
        if len(self.projects) == before:
            self._undo = None
            return [f"no project [{pid}]"], f"error: no project [{pid}]"
        self._save()
        lines = [f"[{p['id']}] {p['name']}  ({p['status']}, {len(p['entry_ids'])} pinned)" for p in self.projects]
        return lines or ["(no projects left)"], f"removed project [{pid}]"

    # -- aggregate views ------------------------------------------------------

    def _cmd_categories(self, rest):
        counts = Counter(e["category"] for e in self.entries)
        if not counts:
            return ["(no entries yet)"], "0 categories"
        lines = [f"{cat}  ({n})" for cat, n in sorted(counts.items(), key=lambda kv: -kv[1])]
        return lines, f"{len(counts)} categories, {len(self.entries)} entries total"

    def _cmd_tags(self, rest):
        counts = Counter(t for e in self.entries for t in e["tags"])
        if not counts:
            return ["(no tags yet)"], "0 tags"
        lines = [f"#{tag}  ({n})" for tag, n in sorted(counts.items(), key=lambda kv: -kv[1])]
        return lines, f"{len(counts)} tags"

    def _cmd_stats(self, rest):
        if not self.entries:
            return ["(no entries yet)"], "0 entries"
        cats = Counter(e["category"] for e in self.entries)
        tags = Counter(t for e in self.entries for t in e["tags"])
        dates = sorted(e["created"] for e in self.entries)
        proj_noun = "project" if len(self.projects) == 1 else "projects"
        lines = [
            f"{len(self.entries)} entries, {len(self.projects)} {proj_noun}",
            f"{len(cats)} categories, {len(tags)} tags",
            f"oldest {dates[0]}  newest {dates[-1]}",
            "",
            "top categories:",
        ]
        lines += [f"  {cat} ({n})" for cat, n in cats.most_common(3)]
        if tags:
            lines.append("")
            lines.append("top tags:")
            lines += [f"  #{tag} ({n})" for tag, n in tags.most_common(3)]
        return lines, f"{len(self.entries)} entries total"

    def _cmd_find(self, rest):
        term = rest.strip().lower()
        if not term:
            return ["usage: find <term>"], "error: empty search"
        results = [
            e for e in self.entries
            if term in e["text"].lower() or term in e["category"].lower() or any(term in t for t in e["tags"])
        ]
        noun = "match" if len(results) == 1 else "matches"
        return self.render_list_view(results), f"{len(results)} {noun} for '{term}'"

    # -- rendering --------------------------------------------------------------

    def _entry_lines(self, entries, width=34):
        lines = []
        for e in entries:
            tagstr = (" {" + " ".join("#" + t for t in e["tags"]) + "}") if e["tags"] else ""
            linkstr = (" ->" + ",".join(str(i) for i in e.get("links", []))) if e.get("links") else ""
            clashstr = (" !" + ",".join(str(i) for i in e.get("clashes", []))) if e.get("clashes") else ""
            body = f"[{e['id']}] {e['category']} — {e['text']}{tagstr}{linkstr}{clashstr}"
            lines.extend(textwrap.wrap(body, width=width, subsequent_indent="    ") or [""])
        return lines

    def render_list_view(self, entries, width=34, max_lines=18):
        if not entries:
            return ["(nothing here yet)", "try: add mood <text> #tag"]
        entries = sorted(entries, key=lambda e: -e["id"])
        lines, shown = [], 0
        for e in entries:
            wrapped = self._entry_lines([e], width=width)
            if len(lines) + len(wrapped) > max_lines - 1 and shown < len(entries):
                lines.append(f"...and {len(entries) - shown} more (narrow with find/list)")
                break
            lines.extend(wrapped)
            shown += 1
        return lines

    def _daily_seed_entry(self):
        if not self.entries:
            return None
        rng = random.Random(date.today().isoformat())
        return rng.choice(self.entries)

    def render_initial(self):
        if not self.entries:
            return ["welcome to paradex.", "", "file the aesthetics you keep", "coming back to. pull a random", "set later to seed a concept.", "", "try:", "  add mood <text> #tag", "  help"]
        seed = self._daily_seed_entry()
        header = ["◈ today's pull", ""] + self._entry_lines([seed]) + ["", "· " * 17, ""]
        return header + self.render_list_view(list(self.entries), max_lines=max(4, 18 - len(header)))

    def initial_status(self):
        if not self.entries:
            return "welcome — try: add mood <text> #tag"
        seed = self._daily_seed_entry()
        return f"{len(self.entries)} entries — today's pull: [{seed['id']}] {seed['category']}"

    def _build_sheet(self, name, entries, kind="BUILD SHEET"):
        by_cat = {}
        for e in entries:
            by_cat.setdefault(e["category"], []).append(e)
        out = [f"PARADEX {kind} — {name}", f"generated {date.today().isoformat()}", ""]
        for cat, es in sorted(by_cat.items()):
            out.append(cat.upper())
            for e in es:
                tagstr = (" [" + " ".join("#" + t for t in e["tags"]) + "]") if e["tags"] else ""
                out.append(f"  - {e['text']}{tagstr}")
            out.append("")
        if kind == "BUILD SHEET":
            out.append("---")
            out.append("seed for:")
            out.append("")
        return "\n".join(out)


def safe_addstr(stdscr, y, x, text, attr=0):
    try:
        stdscr.addstr(y, x, text, attr)
    except curses.error:
        pass


# ---------------------------------------------------------------------------
# shared chrome/content rendering — a plain list[str] box, used by both the
# curses backend (blitted at an x0,y0 offset inside the real terminal) and
# the tkinter backend (the box IS the whole window, no host terminal).
# ---------------------------------------------------------------------------

def render_box_lines(view, status, buf, cursor, fw, fh, inner_w, content_h, title):
    """returns (lines, title_row, input_row, input_col) — lines[i] is exactly
    fw chars wide; title_row/input_row are indices into lines; input_col is
    the char column (within the line) where the text-entry cursor sits.

    border is a subtle bevel: crisp "─│" on the top/left (raised edge), soft
    "░" shade on the bottom/right (recessed edge) — glyph-only, no color."""
    lines = []
    lines.append("┌" + "─" * inner_w + "┐")

    left_box, right_box = "[■]", "[■]"
    label = f" {title} "
    stripe_total = max(0, inner_w - len(left_box) - len(right_box) - len(label))
    left_stripe = "·" * (stripe_total // 2)
    right_stripe = "·" * (stripe_total - stripe_total // 2)
    title_line = (left_box + left_stripe + label + right_stripe + right_box)[:inner_w].ljust(inner_w)
    lines.append("│" + title_line + "░")
    title_row = 1

    lines.append("├" + "─" * inner_w + "┤")

    for i in range(content_h):
        text = (view[i] if i < len(view) else "")[:inner_w].ljust(inner_w)
        lines.append("│" + text + "░")

    status_text = ("◆ " + status)[:inner_w].ljust(inner_w)
    lines.append("│" + status_text + "░")
    lines.append("├" + "─" * inner_w + "┤")

    full_prompt = "> " + "".join(buf)
    cursor_pos = 2 + cursor
    if len(full_prompt) <= inner_w:
        view_start = 0
    else:
        max_start = len(full_prompt) - inner_w
        view_start = min(max(cursor_pos - inner_w + 1, 0), max_start)
        if cursor_pos < view_start:
            view_start = cursor_pos
    visible = full_prompt[view_start:view_start + inner_w].ljust(inner_w)
    input_row = len(lines)
    lines.append("│" + visible + "░")
    input_col = 1 + (cursor_pos - view_start)

    lines.append("░" * (inner_w + 2))

    return lines, title_row, input_row, input_col


CONTENT_H, INNER_W = 18, 34


def handle_key(app, buf, cursor, history, hist_idx, control):
    """apply one logical keypress. `control` is one of the KEY_* sentinels
    below, or a single printable character. returns (buf, cursor, hist_idx,
    view_status_or_None) — view_status_or_None is (view, status) on submit,
    QUIT on quit, else None."""
    if control == "ENTER":
        raw = "".join(buf)
        if raw.strip():
            history.append(raw)
        hist_idx = len(history)
        result = app.dispatch(raw)
        if result is QUIT:
            return buf, cursor, hist_idx, QUIT
        return [], 0, hist_idx, result
    if control == "BACKSPACE":
        if cursor > 0:
            del buf[cursor - 1]
            cursor -= 1
    elif control == "DELETE":
        if cursor < len(buf):
            del buf[cursor]
    elif control == "LEFT":
        cursor = max(0, cursor - 1)
    elif control == "RIGHT":
        cursor = min(len(buf), cursor + 1)
    elif control == "HOME":
        cursor = 0
    elif control == "END":
        cursor = len(buf)
    elif control == "UP":
        if history and hist_idx > 0:
            hist_idx -= 1
            buf = list(history[hist_idx])
            cursor = len(buf)
    elif control == "DOWN":
        if hist_idx < len(history) - 1:
            hist_idx += 1
            buf = list(history[hist_idx])
            cursor = len(buf)
        else:
            hist_idx = len(history)
            buf, cursor = [], 0
    elif isinstance(control, str) and len(control) == 1:
        buf.insert(cursor, control)
        cursor += 1
    return buf, cursor, hist_idx, None


# ---------------------------------------------------------------------------
# curses backend
# ---------------------------------------------------------------------------

def cmd_tui(_args):
    curses.wrapper(_curses_main)


def _curses_main(stdscr):
    curses.curs_set(1)
    curses.start_color()
    curses.init_pair(1, curses.COLOR_BLACK, curses.COLOR_WHITE)
    pair = curses.color_pair(1)
    stdscr.keypad(True)

    term_h, term_w = stdscr.getmaxyx()
    content_h, inner_w = CONTENT_H, INNER_W
    fw, fh = inner_w + 2, content_h + 7
    while fh > term_h - 1 and content_h > 8:
        content_h -= 1
        fh = content_h + 7
    while fw > term_w - 1 and inner_w > 24:
        inner_w -= 2
        fw = inner_w + 2
    if fh > term_h - 1 or fw > term_w - 1:
        stdscr.erase()
        safe_addstr(stdscr, 0, 0, f"terminal too small — need at least {fw + 2} x {fh + 2}")
        stdscr.refresh()
        stdscr.getch()
        return

    x0 = max(0, (term_w - fw) // 2)
    y0 = max(0, (term_h - fh) // 2)

    app = App()
    view = app.render_initial()
    status = app.initial_status()
    buf, cursor = [], 0
    history, hist_idx = [], 0

    while True:
        lines, _title_row, input_row, input_col = render_box_lines(
            view, status, buf, cursor, fw, fh, inner_w, content_h, "PARADEX")
        stdscr.clear()
        for i, line in enumerate(lines):
            attr = pair | (curses.A_BOLD if i == 1 else 0)
            safe_addstr(stdscr, y0 + i, x0, line, attr)
        try:
            stdscr.move(y0 + input_row, x0 + input_col)
        except curses.error:
            pass
        stdscr.refresh()

        ch = stdscr.getch()
        if ch in (10, 13, curses.KEY_ENTER):
            control = "ENTER"
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            control = "BACKSPACE"
        elif ch == curses.KEY_DC:
            control = "DELETE"
        elif ch == curses.KEY_LEFT:
            control = "LEFT"
        elif ch == curses.KEY_RIGHT:
            control = "RIGHT"
        elif ch == curses.KEY_HOME:
            control = "HOME"
        elif ch == curses.KEY_END:
            control = "END"
        elif ch == curses.KEY_UP:
            control = "UP"
        elif ch == curses.KEY_DOWN:
            control = "DOWN"
        elif ch == curses.KEY_RESIZE:
            continue
        elif 32 <= ch < 127:
            control = chr(ch)
        else:
            continue

        buf, cursor, hist_idx, result = handle_key(app, buf, cursor, history, hist_idx, control)
        if result is QUIT:
            break
        if result is not None:
            view, status = result


# ---------------------------------------------------------------------------
# tkinter backend ("window" mode — standalone desktop widget, no host
# terminal emulator; the ASCII box drawn above IS the whole window)
# ---------------------------------------------------------------------------

_TK_KEYSYM_TO_CONTROL = {
    "Return": "ENTER", "KP_Enter": "ENTER",
    "BackSpace": "BACKSPACE", "Delete": "DELETE",
    "Left": "LEFT", "Right": "RIGHT", "Home": "HOME", "End": "END",
    "Up": "UP", "Down": "DOWN",
}


def cmd_window(args):
    if not args.fg:
        _daemonize()

    app = App()
    state = {
        "view": app.render_initial(),
        "status": app.initial_status(),
        "buf": [], "cursor": 0, "history": [], "hist_idx": 0,
    }

    inner_w, content_h = INNER_W, args.rows or CONTENT_H
    fw, fh = inner_w + 2, content_h + 7

    root = tk.Tk(className="paradex")
    root.title("paradex")
    font_name = "Terminus" if _font_available("Terminus") else "DejaVu Sans Mono"
    font = (font_name, args.font_size)
    tk_font = tkfont.Font(root=root, font=font)
    char_w = tk_font.measure("0") or 8
    char_h = tk_font.metrics("linespace") or 16

    text = tk.Text(root, bg="#ffffff", fg="#000000", font=font, bd=0, highlightthickness=0,
                    insertontime=0, cursor="arrow", wrap="none", takefocus=True)
    text.tag_configure("bold", font=(font_name, args.font_size, "bold"))
    text.tag_configure("cursor", background="#000000", foreground="#ffffff")
    text.pack(fill="both", expand=True)
    text.config(state="disabled")

    width_px = fw * char_w
    height_px = fh * char_h
    if args.geometry:
        root.geometry(args.geometry)
    else:
        sx = (root.winfo_screenwidth() - width_px) // 2
        sy = (root.winfo_screenheight() - height_px) // 2
        root.geometry(f"{width_px}x{height_px}+{max(0, sx)}+{max(0, sy)}")
    root.resizable(False, False)

    def render():
        lines, title_row, input_row, input_col = render_box_lines(
            state["view"], state["status"], state["buf"], state["cursor"],
            fw, fh, inner_w, content_h, "PARADEX")
        text.config(state="normal")
        text.delete("1.0", "end")
        for i, line in enumerate(lines):
            if i == input_row and 0 <= input_col < len(line):
                text.insert("end", line[:input_col])
                text.insert("end", line[input_col], ("cursor",))
                text.insert("end", line[input_col + 1:])
            elif i == title_row:
                text.insert("end", line, ("bold",))
            else:
                text.insert("end", line)
            text.insert("end", "\n")
        text.config(state="disabled")

    def on_key(event):
        keysym = event.keysym
        if keysym == "Escape":
            root.destroy()
            return "break"
        control = _TK_KEYSYM_TO_CONTROL.get(keysym)
        if control is None:
            ch = event.char
            if not ch or not (32 <= ord(ch) < 127):
                return "break"
            control = ch
        buf, cursor, hist_idx, result = handle_key(
            app, state["buf"], state["cursor"], state["history"], state["hist_idx"], control)
        if result is QUIT:
            root.destroy()
            return "break"
        state["buf"], state["cursor"], state["hist_idx"] = buf, cursor, hist_idx
        if result is not None:
            state["view"], state["status"] = result
        render()
        return "break"

    root.bind("<Key>", on_key)
    root.protocol("WM_DELETE_WINDOW", root.destroy)
    render()
    text.focus_set()
    root.lift()
    root.focus_force()
    root.mainloop()


def _font_available(name: str) -> bool:
    try:
        return name in tkfont.families()
    except Exception:
        return False


def _daemonize():
    if os.fork() > 0:
        sys.exit(0)
    os.setsid()
    if os.fork() > 0:
        sys.exit(0)
    sys.stdout.flush()
    sys.stderr.flush()
    devnull = os.open(os.devnull, os.O_RDWR)
    os.dup2(devnull, 0)
    os.dup2(devnull, 1)
    os.dup2(devnull, 2)


# ---------------------------------------------------------------------------
# cli
# ---------------------------------------------------------------------------

def main():
    p = argparse.ArgumentParser(prog="paradex", description="retro-mac aesthetics catalogue")
    sub = p.add_subparsers(dest="command")

    p_tui = sub.add_parser("tui", help="run in the current terminal (default)")
    p_tui.set_defaults(func=cmd_tui)

    p_win = sub.add_parser("window", help="open a standalone desktop widget window")
    p_win.add_argument("--geometry", default=None, help="e.g. 320x480+100+100")
    p_win.add_argument("--font-size", type=int, default=13)
    p_win.add_argument("--rows", type=int, default=None, help="content rows (default 18)")
    p_win.add_argument("--fg", action="store_true", help="stay attached to this shell instead of daemonizing")
    p_win.set_defaults(func=cmd_window)

    args = p.parse_args()
    if args.command is None:
        args.func = cmd_tui
    args.func(args)


if __name__ == "__main__":
    main()
